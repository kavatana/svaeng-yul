# ─────────────────────────────────────────────────────────────
# Svaeng-Yul environment variables
# Copy this file to `.env.local` and fill in real values.
# The app runs in DEMO MODE (in-memory seed data) when Supabase
# variables are absent, so you can explore the UI with zero setup.
#
# ⚠️  Leave these UNSET for the public demo deploy — that keeps the
#     app in credential-free demo mode (the intended portfolio path).
# ─────────────────────────────────────────────────────────────

# Supabase — from your project's Settings → API (LIVE mode only)
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Service-role key — SERVER ONLY. Never expose to the client or commit it.
# Used by seed scripts and admin-only server operations.
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# AI (Anthropic) — powers quiz hints and dispute analysis.
# Without a key, the app falls back to safe canned hints/verdicts.
ANTHROPIC_API_KEY=
# Optional model overrides (sensible defaults are used if unset)
ANTHROPIC_HINT_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_DISPUTE_MODEL=claude-sonnet-4-6
